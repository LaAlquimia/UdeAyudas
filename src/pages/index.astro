---
import BaseLayout from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Manifesto from '../components/Manifesto.astro';
import Modules from '../components/Modules.astro';
import Architecture from '../components/Architecture.astro';
import Fuentes from '../components/Fuentes.astro';
import Rubrica from '../components/Rubrica.astro';
import Footer from '../components/Footer.astro';
import TransitionOverlay from '../components/TransitionOverlay.astro';
---

<BaseLayout title="UdeAyudas | La norma se vuelve conversación">
  <Nav />
  <main>
    <Hero />
    <Manifesto />
    <Modules />
    <Architecture />
    <Fuentes />
    <Rubrica />
