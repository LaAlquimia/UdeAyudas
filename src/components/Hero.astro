---
import GlassCard from './GlassCard.astro';
---

<section class="hero">
  <div class="container">
    <div class="hero-badge glass">
      <span>🎓</span>
      <span>Universidad de Antioquia</span>
    </div>
    <h1>UdeAyudas</h1>
    <p>
      Tu asistente inteligente para los trámites y procesos universitarios de la
      <strong>Universidad de Antioquia</strong>. Resolvemos tus dudas sobre
      matrícula, certificados, homologaciones, calendario académico, becas y
      más, en español y al instante.
    </p>
    <div class="hero-actions">
      <a href="/chatbot" class="glass-btn accent">
        Hablar con el asistente →
      </a>
      <a href="#features" class="glass-btn">
        Conoce qué puede hacer
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 5rem 0 2rem;
  }
</style>
