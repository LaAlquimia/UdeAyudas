---
---

<section class="hero-section">
  <div class="hero-bg">
    <div class="hero-overlay"></div>
    <div class="hero-fade"></div>
    <div class="hero-green-glow"></div>
  </div>

  <div class="hero-content">
    <div class="hero-grid">
      <div class="hero-inner">

      <span class="eyebrow">Agente universitario de la UdeA · 1803</span>

      <h1 class="display">
        <span style="white-space: nowrap;">Tu agente universitario:</span><br>
        respuestas claras,<br>
        sin perderte entre <em class="grad-text">PDFs</em>.
      </h1>

      <p class="lede">
        UdeAyuda orquesta una red de agentes especializados sobre el corpus documental de la UdeA. Consulta reglamentos, procesos y trámites en lenguaje natural — con citas exactas al artículo, parágrafo y fuente original.
      </p>

      <div class="cta-row">
        <a href="/chatbot" class="btn-primary cta-enter">
          <span class="dot-pulse"></span>
          Hablar con el agente
          <span class="arrow-pill">→</span>
        </a>
        <a href="#agentes" class="btn-ghost">Ver los agentes</a>
      </div>

      <div class="stats-row">
        <div class="stat">
          <span class="stat-num grad-text">4</span>
          <span class="stat-lbl">Agentes IA</span>
        </div>
        <div class="stat-div"></div>
        <div class="stat">
          <span class="stat-num grad-text">0</span>
          <span class="stat-lbl">Alucinaciones</span>
        </div>
        <div class="stat-div"></div>
        <div class="stat">
          <span class="stat-num grad-text">100%</span>
          <span class="stat-lbl">Citado y verificado</span>
        </div>
      </div>

      </div>

      <!-- Chat Visual Mockup -->
      <div class="hero-visual">
        <div class="chat-mockup glass-panel">
          <div class="chat-mockup-header">
            <div class="mockup-dot r"></div>
            <div class="mockup-dot y"></div>
            <div class="mockup-dot g"></div>
          </div>
          <div class="chat-mockup-body">
            <div class="mockup-msg user" id="mockup-msg-1" style="opacity:0">¿Hasta cuándo puedo cancelar materias este semestre?</div>
            <div class="mockup-msg ai" id="mockup-msg-2" style="opacity:0">
              <span class="typing-indicator" id="typ1"><span class="dot"></span><span class="dot"></span><span class="dot"></span></span>
              <div class="msg-content hidden" id="msg1">
                ¡Hola! Tienes hasta el viernes de la <strong>semana 8</strong> del calendario académico (15 de marzo). ¿Te muestro cómo hacerlo en el portal SSOFI?
                <br>
                <span class="citation">✓ Reg. Estudiantil Art. 64</span>
              </div>
            </div>
            <div class="mockup-msg user" id="mockup-msg-3" style="opacity:0">Sí, por favor.</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function runChatMockup() {
    const typ1 = document.getElementById('typ1');
    const msg1 = document.getElementById('msg1');
    const m1 = document.getElementById('mockup-msg-1');
    const m2 = document.getElementById('mockup-msg-2');
    const m3 = document.getElementById('mockup-msg-3');

    if(!typ1 || !msg1 || !m1) return;

    // Reset
    m1.style.animation = 'none';
    m2.style.animation = 'none';
    m3.style.animation = 'none';
    typ1.classList.remove('hidden');
    msg1.classList.add('hidden');

    // Trigger reflow
    void m1.offsetWidth;

    // Start
    m1.style.animation = 'slideUp 0.6s 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards';
    m2.style.animation = 'slideUp 0.6s 1.8s cubic-bezier(0.16, 1, 0.3, 1) forwards';
    m3.style.animation = 'slideUp 0.6s 8.5s cubic-bezier(0.16, 1, 0.3, 1) forwards';

    // AI typing finishes at 4.5s
    setTimeout(() => {
      typ1.classList.add('hidden');
      msg1.classList.remove('hidden');
    }, 4500);

    // Smooth fade out before reset at 14.5s
    setTimeout(() => {
      m1.style.animation = 'fadeOut 0.4s forwards';
      m2.style.animation = 'fadeOut 0.4s forwards';
      m3.style.animation = 'fadeOut 0.4s forwards';
    }, 14500);
  }

  // Ensure DOM is fully parsed
  document.addEventListener("DOMContentLoaded", () => {
    runChatMockup();
    setInterval(runChatMockup, 15000); // 15 seconds loop
  });
</script>

<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: var(--grad-warm-bg);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(2, 105, 55, 0.06);
  }

  .hero-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 30%;
    background: linear-gradient(to bottom, transparent, var(--paper));
    z-index: 1;
  }

  .hero-green-glow {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 80vw;
    height: 80vw;
    background: radial-gradient(circle, rgba(2, 105, 55, 0.08) 0%, transparent 65%);
    pointer-events: none;
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 var(--gutter);
    width: 100%;
    padding-top: 48px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-inner {
    max-width: 52rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Eyebrow pill */
  .eyebrow {
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--coral-600);
    background: rgba(2, 105, 55, 0.09);
    border: 1px solid rgba(2, 105, 55, 0.28);
    padding: 0.3rem 0.85rem;
    border-radius: 999px;
  }

  /* Headline — ensure grad-text is never clipped */
  .display {
    font-size: clamp(1.4rem, 6.5vw, 4rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
    padding-bottom: 0.08em; /* prevent descender/gradient clip */
  }

  /* Ensure all grad-text has room to render */
  .grad-text {
    display: inline-block;
    padding-bottom: 0.05em;
  }

  .lede {
    font-size: clamp(0.95rem, 1.3vw, 1.1rem);
    max-width: 38rem;
    color: var(--muted);
    line-height: 1.65;
    margin: 0;
  }

  /* CTAs */
  .cta-row {
    display: flex;
    gap: 0.875rem;
    align-items: center;
    flex-wrap: wrap;
    margin: 0;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    background: var(--ink);
    color: white;
    padding: 0.65rem 0.65rem 0.65rem 1.15rem;
    border-radius: 999px;
    font-weight: 500;
    font-size: 0.95rem;
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
    white-space: nowrap;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.18);
  }

  .dot-pulse {
    width: 7px;
    height: 7px;
    background: var(--coral-400);
    border-radius: 50%;
    display: inline-block;
    animation: pulse 2s infinite;
    flex-shrink: 0;
  }

  .arrow-pill {
    background: var(--grad-orange);
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    font-size: 0.95rem;
  }

  .btn-ghost {
    padding: 0.65rem 1.35rem;
    border-radius: 999px;
    border: 1.5px solid var(--line-strong);
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--ink);
    transition: all 0.2s;
    white-space: nowrap;
  }
  .btn-ghost:hover {
    border-color: var(--ink);
    background: rgba(0,0,0,0.03);
  }

  /* Stats glassmorphism bar */
  .stats-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.1rem 1.75rem;
    background: rgba(255, 255, 255, 0.52);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.8);
    border-radius: 14px;
    width: fit-content;
    box-shadow: 0 4px 20px rgba(2, 105, 55, 0.14);
    margin: 0;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    min-width: 70px;
    text-align: center;
  }

  .stat-num {
    font-family: 'Azurio', serif;
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1;
  }

  .stat-lbl {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .stat-div {
    width: 1px;
    height: 2rem;
    background: var(--line-strong);
    flex-shrink: 0;
    opacity: 0.5;
  }

  .mono { font-family: 'JetBrains Mono', monospace; }

  /* Chat Mockup Styles */
  .hero-visual {
    perspective: 1000px;
  }
  .glass-panel {
    background: rgba(255, 255, 255, 0.65);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.9);
    border-radius: 24px;
    box-shadow: 0 24px 48px rgba(2, 105, 55, 0.12), inset 0 1px 0 rgba(255,255,255,1);
    transform: rotateY(-8deg) rotateX(4deg) translateY(0);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s;
  }
  .glass-panel:hover {
    transform: rotateY(0deg) rotateX(0deg) translateY(-10px);
    box-shadow: 0 32px 64px rgba(2, 105, 55, 0.16), inset 0 1px 0 rgba(255,255,255,1);
  }

  .chat-mockup-header {
    background: rgba(255, 255, 255, 0.4);
    padding: 1.2rem;
    display: flex; gap: 8px;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    border-radius: 24px 24px 0 0;
  }
  .mockup-dot { width: 12px; height: 12px; border-radius: 50%; }
  .mockup-dot.r { background: #FF5F56; box-shadow: 0 0 4px rgba(255,95,86,0.5); }
  .mockup-dot.y { background: #FFBD2E; box-shadow: 0 0 4px rgba(255,189,46,0.5); }
  .mockup-dot.g { background: #27C93F; box-shadow: 0 0 4px rgba(39,201,63,0.5); }

  .chat-mockup-body {
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    height: 420px; /* Fixed height prevents expanding layout */
  }

  .mockup-msg {
    padding: 1rem 1.25rem;
    border-radius: 18px;
    font-size: 0.95rem;
    line-height: 1.5;
    max-width: 85%;
    opacity: 0;
    font-family: 'Inter', sans-serif;
  }
  .mockup-msg.user {
    background: var(--ink);
    color: white;
    align-self: flex-end;
    border-bottom-right-radius: 4px;
    box-shadow: 0 8px 16px rgba(0,0,0,0.1);
  }
  .mockup-msg.ai {
    background: white;
    color: var(--body);
    border: 1px solid var(--line);
    align-self: flex-start;
    border-bottom-left-radius: 4px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
  }

  .citation {
    display: inline-flex; align-items: center; gap: 0.3rem;
    background: rgba(15,110,86,0.07); border: 1px solid rgba(15,110,86,0.2);
    color: #0f6e56; border-radius: 6px; padding: 0.2rem 0.55rem;
    font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; margin-top: 0.6rem;
  }

  .slide-up-1 { animation: slideUp 0.6s 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .slide-up-2 { animation: slideUp 0.6s 1.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .slide-up-3 { animation: slideUp 0.6s 4.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeOut {
    from { opacity: 1; transform: translateY(0); }
    to { opacity: 0; transform: translateY(-5px); }
  }

  .typing-indicator { display: flex; gap: 4px; align-items: center; height: 24px; }
  .typing-indicator .dot { width: 6px; height: 6px; background: var(--muted); border-radius: 50%; animation: typeDot 1.4s infinite ease-in-out both; }
  .typing-indicator .dot:nth-child(1) { animation-delay: -0.32s; }
  .typing-indicator .dot:nth-child(2) { animation-delay: -0.16s; }
  @keyframes typeDot { 0%, 80%, 100% { transform: scale(0); } 40% { transform: scale(1); } }
  .hidden { display: none; }

  @media (max-width: 960px) {
    .hero-grid { grid-template-columns: 1fr; gap: 3rem; }
    .hero-visual { max-width: 500px; margin: 0 auto; }
  }

  @media (max-width: 768px) {
    .hero-content { padding-top: 80px; }
    .display { font-size: clamp(1.9rem, 6vw, 2.8rem); }
    .stats-row { gap: 1rem; padding: 0.9rem 1.25rem; }
    .stat-num { font-size: 1.3rem; }
    .stat-div { height: 1.5rem; }
  }

  @media (max-width: 480px) {
    .stats-row { flex-wrap: wrap; justify-content: center; }
    .stat-div { display: none; }
  }
</style>
