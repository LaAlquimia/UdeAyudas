---
import GlassCard from './GlassCard.astro';
---

<section class="hero">
  <div class="container">
    <div class="hero-badge glass">
      <span>🚀</span>
      <span>Deploy Hackathon 2026</span>
    </div>
    <h1>NeuralSync AI</h1>
    <p>
      Un agente de inteligencia artificial autónomo que sincroniza, analiza y optimiza
      tus flujos de trabajo en tiempo real. Construido para la próxima generación
      de productividad impulsada por IA.
    </p>
    <div class="hero-actions">
      <a href="/chatbot" class="glass-btn accent">
        Probar Chatbot →
      </a>
      <a href="#features" class="glass-btn">
        Conocer más
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 5rem 0 2rem;
  }
</style>
