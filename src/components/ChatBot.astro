<div class="chat-container glass" id="chatContainer">
  <div class="chat-header">
    <div class="chat-header-left">
      <span class="chat-header-title">NeuralSync</span>
    </div>
    <div class="chat-header-right">
      <select class="chat-model-select" id="modelSelect">
        <option value="openai/gpt-4o-mini">GPT-4o Mini</option>
        <option value="openai/gpt-4o">GPT-4o</option>
        <option value="anthropic/claude-sonnet-4-20250514">Claude Sonnet 4</option>
        <option value="google/gemini-2.0-flash-001">Gemini 2.0 Flash</option>
        <option value="meta-llama/llama-4-maverick-17b-128e-instruct">Llama 4 Maverick</option>
        <option value="deepseek/deepseek-chat">DeepSeek V3</option>
        <option value="mistralai/mistral-small-3.1-24b-instruct">Mistral Small 3.1</option>
      </select>
    </div>
  </div>

  <div class="chat-messages" id="chatMessages">
    <div class="message ai welcome">
      <p>Hola, soy NeuralSync. Puedes preguntarme lo que necesites.</p>
    </div>
  </div>

  <div class="chat-input-area">
    <textarea
      class="chat-input"
      id="chatInput"
      placeholder="Escribe un mensaje..."
      rows="1"
      maxlength="4000"
    ></textarea>
    <button class="chat-send" id="chatSend" aria-label="Enviar mensaje">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"></line>
        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
      </svg>
    </button>
  </div>
</div>

<script>
  import { marked } from 'marked';
  import DOMPurify from 'dompurify';

  // Allow only the markdown subset that our chat replies can plausibly contain.
  // We keep it tight on purpose: no inline event handlers, no <script>, no <style>,
  // no <iframe>, no <object>, no <embed>, no <form>, no javascript: URLs.
  const PURIFY_CONFIG = {
    ALLOWED_TAGS: [
      'a', 'b', 'i', 'em', 'strong', 'u', 's', 'code', 'pre', 'kbd', 'samp',
      'p', 'br', 'hr', 'blockquote',
      'h1', 'h2', 'h3', 'h4', 'h5', 'h6',
      'ul', 'ol', 'li',
      'table', 'thead', 'tbody', 'tr', 'th', 'td',
      'span', 'div',
      'img',
    ],
    ALLOWED_ATTR: ['href', 'title', 'alt', 'src', 'rel', 'target', 'lang', 'class'],
    ALLOWED_URI_REGEXP: /^(?:(?:https?|mailto|tel):|[^a-z]|[a-z+.\-]+(?:[^a-z+.\-:]|$))/i,
    FORBID_TAGS: ['script', 'style', 'iframe', 'object', 'embed', 'form', 'input', 'button', 'textarea', 'select', 'link', 'meta', 'base'],
    FORBID_ATTR: ['style', 'onerror', 'onload', 'onclick', 'onmouseover', 'onfocus', 'onblur', 'srcdoc'],
  };

  // Force every link to open safely: rel="noopener noreferrer" + target="_blank".
  // marked sometimes emits bare <a> tags that could point at javascript: if a
  // malicious prompt got the model to emit one; DOMPurify's URI regexp already
  // blocks javascript: but we layer this on for defense in depth.
  DOMPurify.addHook('afterSanitizeAttributes', (node) => {
    if (node.tagName === 'A') {
      node.setAttribute('rel', 'noopener noreferrer');
      node.setAttribute('target', '_blank');
    }
  });

  const messagesEl = document.getElementById('chatMessages');
  const inputEl = document.getElementById('chatInput');
  const sendEl = document.getElementById('chatSend');
  const modelSelect = document.getElementById('modelSelect');
  let loading = false;

  function renderMarkdown(text) {
    const rawHtml = marked.parse(text, { breaks: true });
    return DOMPurify.sanitize(rawHtml, PURIFY_CONFIG);
  }

  function addMessage(text, role) {
    const div = document.createElement('div');
    div.className = `message ${role}`;
    if (role === 'ai') {
      // renderMarkdown returns already-sanitized HTML; the innerHTML assignment
      // is safe because DOMPurify has stripped any executable payload.
      div.innerHTML = renderMarkdown(text);
    } else {
      div.textContent = text;
    }
    messagesEl.appendChild(div);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function removeTyping() {
    const typing = document.querySelector('.message.ai.typing');
    if (typing) typing.remove();
  }

  function showTyping() {
    const div = document.createElement('div');
    div.className = 'message ai typing';
    div.innerHTML = '<div class="typing-dots"><span></span><span></span><span></span></div>';
    messagesEl.appendChild(div);
    messagesEl.scrollTop = messagesEl.scrollHeight;
    return div;
  }

  function autoResizeTextarea() {
    inputEl.style.height = 'auto';
    inputEl.style.height = Math.min(inputEl.scrollHeight, 200) + 'px';
  }

  async function sendMessage() {
    const text = inputEl.value.trim();
    if (!text || loading) return;

    inputEl.value = '';
    autoResizeTextarea();
    addMessage(text, 'user');
    loading = true;
    sendEl.disabled = true;

    showTyping();

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          message: text,
          model: modelSelect.value,
        }),
      });

      removeTyping();

      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        addMessage(err.error || 'Error al conectar con el servidor. Intenta de nuevo.', 'ai');
        return;
      }

      const data = await res.json();
      addMessage(data.reply, 'ai');
    } catch {
      removeTyping();
      addMessage('Error de conexión. Verifica tu internet e intenta de nuevo.', 'ai');
    } finally {
      loading = false;
      sendEl.disabled = false;
      inputEl.focus();
    }
  }

  sendEl.addEventListener('click', sendMessage);
  inputEl.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  inputEl.addEventListener('input', autoResizeTextarea);

  inputEl.focus();
</script>
