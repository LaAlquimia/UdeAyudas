# ── OpenRouter (motor genérico multi-modelo) ────────────────────────────────
# Requerido para responder con el motor "OpenRouter IA" del selector del chat.
# Sin esta key, ese motor devuelve 500 con un mensaje pidiendo configurarla.
# Obtén tu API key en https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# ── Copiloto UdeA (motor institucional) ──────────────────────────────────────
# URL del backend LangGraph + FastAPI ("Copiloto Administrativo") que se usa
# cuando el usuario selecciona el motor "Copiloto UdeA" en el chat. Sin auth,
# solo texto, devuelve una respuesta con normativa y procedimientos UdeA.
# El default apunta al deploy de Render; cámbialo para apuntar a un entorno
# local o de staging.
COPILOTO_API_URL=https://copiloto-admin-udea.onrender.com/api/invoke

# ── OpenRouter analytics (opcional) ──────────────────────────────────────────
# URL que OpenRouter usa como HTTP-Referer para que las analíticas reflejen
# el tráfico correcto. En local usa http://localhost:4321; en producción el
# default (https://udeayudas.netlify.app) ya es correcto, así que solo
# necesitas configurarlo si despliegas bajo un dominio distinto.
# PUBLIC_SITE_URL=https://udeayudas.netlify.app

# ── Orígenes permitidos para CORS del endpoint /api/chat (opcional) ─────────
# Lista separada por comas de orígenes extra permitidos para hacer POST a
# /api/chat, además de los defaults (localhost:4321, laalquimiai.netlify.app,
# udeayudas.netlify.app). Úsalo si despliegas bajo otro subdominio de Netlify
# o un dominio personalizado; sin esto el endpoint devuelve 403.
# ALLOWED_ORIGINS=https://mi-dominio.com,https://otro.example.com