# Required: OpenRouter API key. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...here

# Optional: public site URL used as the HTTP-Referer header when calling
# OpenRouter. Defaults to https://neuralsync-ai.netlify.app. Set this to
# http://localhost:4321 during local dev so OpenRouter analytics are accurate.
# PUBLIC_SITE_URL=https://neuralsync-ai.netlify.app

# Optional: extra comma-separated origins allowed to call POST /api/chat
# (in addition to the built-in defaults: localhost:4321, neuralsync-ai.netlify.app,
# laalquimia.netlify.app). Use this when you deploy under a different Netlify
# subdomain or a custom domain.
# ALLOWED_ORIGINS=https://your-site.netlify.app,https://www.your-domain.com
